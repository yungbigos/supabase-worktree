#!/usr/bin/env bash
#
# supabase-worktree — spin up an isolated Supabase stack per project or git worktree.
#
# Each instance gets a deterministic port offset derived from its name, a unique
# `project_id`, and symlinks back to the source `supabase/` directory so
# migrations / seeds / schemas / functions / templates / tests all just work.
#
# The instance name is chosen in this order of precedence:
#   1. $SUPABASE_WORKTREE_NAME           (explicit override)
#   2. git worktree branch (when inside a git work tree, slugified)
#   3. a deterministic keyword derived from sha1(ROOT)   (plain-directory mode)
#
# Subcommands: init | up | down | restore <dump> | psql [args] | status | version | help
#
set -euo pipefail

VERSION="0.5.0"

# --- early dispatch for context-free subcommands -----------------------------
# `version` / `--version` / `-v` must work without a project root so that
# `brew test`, CI smoke checks, and ad-hoc PATH queries don't blow up. Same
# for plain `help` — the resolved-state block in the full help requires ROOT,
# but the usage section does not.
case "${1:-}" in
  version|--version|-v)
    echo "supabase-worktree ${VERSION}"
    exit 0
    ;;
esac

# --- locate ROOT (the directory containing supabase/) ------------------------

ROOT=""
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  ROOT="$(git rev-parse --show-toplevel)"
else
  # Walk up from $PWD looking for a supabase/ directory.
  dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/supabase" ]]; then
      ROOT="$dir"
      break
    fi
    dir="$(dirname "$dir")"
  done
fi

if [[ -z "$ROOT" || ! -d "$ROOT/supabase" ]]; then
  # Allow `help` to run without a project context so users can discover
  # commands from anywhere on $PATH. The full help prints a "resolved for
  # this invocation" block; without ROOT we just print the usage section.
  case "${1:-help}" in
    help|-h|--help)
      cat <<EOF
supabase-worktree ${VERSION}

Usage: $(basename "$0") <command> [args...]

Commands:
  init                  Generate .supabase-worktree/supabase/config.toml + symlinks
  up [supabase args]    supabase start in the isolated stack
  down [supabase args]  supabase stop in the isolated stack
  status                Show root, project_id, ports, db url, running state
  restore <dump> [-y]   Restore a custom-format pg_dump into the isolated DB
                        (two-pass: app schemas first, then auth/storage data-only)
  psql [args...]        psql into the isolated DB
  ports [--table|--urls|--all]
                        List every reservable port slot. Default mode prints
                        the Supabase auth redirect URIs to paste into your
                        OAuth provider whitelist (Google, GitHub, ...) once
                        so new worktrees don't trigger a console roundtrip.
  hook                  Run \$ROOT/.supabase-worktree.hook on demand (fired
                        automatically after init/up; useful for re-running)
  version               Print the installed version
  help                  Show this message

Env overrides:
  SUPABASE_WORKTREE_NAME         override the derived instance name
  SUPABASE_WORKTREE_PROJECT_ID   override the auto-detected base project_id
  SUPABASE_WORKTREE_PORT_OFFSET  pin a specific port offset
  SUPABASE_WORKTREE_OFFSETS      comma-separated list of reservable offsets
                                 (default: 50 slots, multiples of 100, 0..4900)

Run inside a project that has a supabase/ folder to see the resolved ports
and db url for the current worktree.
EOF
      exit 0
      ;;
  esac
  echo "supabase-worktree: no supabase/ directory found in this tree" >&2
  echo "  (run inside a project that has a supabase/ folder, or set SUPABASE_WORKTREE_NAME to bypass)" >&2
  exit 1
fi

cd "$ROOT"

# --- derive instance NAME ----------------------------------------------------

KEYWORDS=(
  swift lively brisk bold calm eager fancy gentle happy jolly keen lucky
  merry nimble proud quiet rapid silver tidy upbeat vivid witty zen amber
  azure crimson dusky ember flax frost glow hazel indigo ivory jade kale
  lilac maple navy ochre opal pearl plum rose ruby sage scarlet sienna
  slate sunny teal topaz umber violet wheat willow zephyr ash bay clay
  dew fern fjord glade gold haze
)

derive_keyword() {
  local seed="$1"
  local hash idx
  hash="$(printf '%s' "$seed" | shasum -a 1 | awk '{print $1}')"
  idx=$((0x${hash:0:6} % ${#KEYWORDS[@]}))
  printf '%s' "${KEYWORDS[$idx]}"
}

slugify() {
  printf '%s' "$1" | tr '/' '-' | tr '[:upper:]' '[:lower:]'
}

WORKTREE_NAME="${SUPABASE_WORKTREE_NAME:-}"
if [[ -z "$WORKTREE_NAME" ]]; then
  # Try git worktree branch first
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    branch="$(git -C "$ROOT" symbolic-ref --short -q HEAD || true)"
    if [[ -n "$branch" ]]; then
      WORKTREE_NAME="$(slugify "$branch")"
    fi
  fi
fi
if [[ -z "$WORKTREE_NAME" ]]; then
  WORKTREE_NAME="$(derive_keyword "$ROOT")"
fi

# --- derive base project_id from supabase/config.toml ------------------------

SOURCE_CONFIG="$ROOT/supabase/config.toml"
if [[ ! -f "$SOURCE_CONFIG" ]]; then
  echo "supabase-worktree: $SOURCE_CONFIG not found" >&2
  exit 1
fi

BASE_PROJECT_ID="${SUPABASE_WORKTREE_PROJECT_ID:-}"
if [[ -z "$BASE_PROJECT_ID" ]]; then
  BASE_PROJECT_ID="$(awk -F'"' '/^[[:space:]]*project_id[[:space:]]*=/ {print $2; exit}' "$SOURCE_CONFIG")"
fi
if [[ -z "$BASE_PROJECT_ID" ]]; then
  BASE_PROJECT_ID="$(basename "$ROOT")"
fi

PROJECT_ID="${BASE_PROJECT_ID}-${WORKTREE_NAME}"

# --- derive port offset ------------------------------------------------------

# Reservable port-offset slots. A worktree's offset is picked deterministically
# from this list: OFFSETS[sha1(name) % len(OFFSETS)]. The whole point of
# enumerating slots (vs. the old `sha1 % 50 * 100` formula) is that every
# possible derived port is known up-front, so OAuth providers (Google, etc.)
# can be whitelisted ONCE with the full set of redirect URIs and never need
# touching when a new worktree is created.
#
# The default list is the same 50 slots (multiples of 100, 0..4900) the old
# formula generated, so existing worktrees keep their offset across upgrade.
# Override the entire list with $SUPABASE_WORKTREE_OFFSETS (comma-separated).
# Pin a specific slot with $SUPABASE_WORKTREE_PORT_OFFSET (skips derivation).
OFFSETS=(
  0    100  200  300  400  500  600  700  800  900
  1000 1100 1200 1300 1400 1500 1600 1700 1800 1900
  2000 2100 2200 2300 2400 2500 2600 2700 2800 2900
  3000 3100 3200 3300 3400 3500 3600 3700 3800 3900
  4000 4100 4200 4300 4400 4500 4600 4700 4800 4900
)

if [[ -n "${SUPABASE_WORKTREE_OFFSETS:-}" ]]; then
  IFS=',' read -r -a OFFSETS <<<"$SUPABASE_WORKTREE_OFFSETS"
fi

if [[ ${#OFFSETS[@]} -eq 0 ]]; then
  echo "supabase-worktree: OFFSETS list is empty (check \$SUPABASE_WORKTREE_OFFSETS)" >&2
  exit 1
fi

if [[ -n "${SUPABASE_WORKTREE_PORT_OFFSET:-}" ]]; then
  OFFSET="$SUPABASE_WORKTREE_PORT_OFFSET"
else
  HASH="$(printf '%s' "$WORKTREE_NAME" | shasum -a 1 | awk '{print $1}')"
  SLOT=$((0x${HASH:0:6} % ${#OFFSETS[@]}))
  OFFSET="${OFFSETS[$SLOT]}"
fi

WT_API=$((54321 + OFFSET))
WT_DB=$((54322 + OFFSET))
WT_STUDIO=$((54323 + OFFSET))
WT_INBUCKET=$((54324 + OFFSET))
WT_ANALYTICS=$((54327 + OFFSET))
WT_POOLER=$((54329 + OFFSET))
WT_SHADOW=$((54330 + OFFSET))
WT_INSPECTOR=$((8083 + OFFSET))

WT_DIR="${ROOT}/.supabase-worktree"
WT_SB_DIR="${WT_DIR}/supabase"
WT_CONFIG="${WT_SB_DIR}/config.toml"
WT_ENV="${WT_DIR}/.env"
ROOT_ENV_LOCAL="${ROOT}/.env.local"
# Optional user-supplied script run after init/up wires up env + config. Lives
# at the repo root so it survives `.supabase-worktree/` regeneration and gets
# committed alongside the project (unlike anything inside .supabase-worktree/).
# See `run_post_init_hook` for the env it receives.
HOOK_FILE="${ROOT}/.supabase-worktree.hook"
DB_URL="postgresql://postgres:postgres@127.0.0.1:${WT_DB}/postgres"

# Derived Next.js / app dev-server port — same offset bucket as Supabase, so
# parallel worktrees don't collide on :3000. Range 3000..3049 across 50 slots.
WT_NEXT_PORT=$((3000 + OFFSET / 100))
# Use `localhost` (not 127.0.0.1) for the user-facing URLs — OAuth providers
# (Google, etc.) typically have `http://localhost:<port>/...` registered, and
# the Next dev server's own banner also reports `localhost`. SUPABASE_URL still
# uses 127.0.0.1 because that's how the app talks to the API container.
SITE_URL="http://localhost:${WT_NEXT_PORT}"

# --- env helpers -------------------------------------------------------------

# write_wt_env — generates .supabase-worktree/.env, the file `supabase` reads
# for env() substitution in config.toml. Always overwritten (idempotent) so
# edits to the repo .env propagate on the next `init` / `up`.
#
# Contents: a snapshot of $ROOT/.env (if present) followed by per-worktree
# overrides — instance ports, site URL, etc. — that downstream config.toml
# env() lookups can resolve.
# Keys we override on every write — kept in one place so the two emitters
# (`write_wt_env`, `write_root_env_local`) and the snapshot filter can't drift.
OVERRIDE_KEYS=(
  SUPABASE_WORKTREE_NAME
  SUPABASE_WORKTREE_PORT_OFFSET
  SUPABASE_WORKTREE_NEXT_PORT
  PORT
  SUPABASE_URL
  NEXT_PUBLIC_SUPABASE_URL
  SITE_URL
  NEXT_PUBLIC_APP_URL
)

emit_overrides() {
  echo "# === supabase-worktree per-instance overrides ==="
  echo "SUPABASE_WORKTREE_NAME=${WORKTREE_NAME}"
  echo "SUPABASE_WORKTREE_PORT_OFFSET=${OFFSET}"
  echo "SUPABASE_WORKTREE_NEXT_PORT=${WT_NEXT_PORT}"
  # PORT is what Next.js / most Node frameworks read at process start — by
  # baking it into .env.local, bun-loaded env propagates to the spawned dev
  # server without needing shell expansion in the package.json script (which
  # doesn't work — bun does not expose .env-loaded vars to script subshells).
  echo "PORT=${WT_NEXT_PORT}"
  echo "SUPABASE_URL=http://127.0.0.1:${WT_API}"
  echo "NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:${WT_API}"
  echo "SITE_URL=${SITE_URL}"
  echo "NEXT_PUBLIC_APP_URL=${SITE_URL}"
}

# emit_snapshot_without_overrides <file> — prints <file> with any line
# assigning one of OVERRIDE_KEYS removed, so the appended override block wins
# without leaving stale duplicates above.
emit_snapshot_without_overrides() {
  local src="$1"
  # Build a regex like ^(KEY1|KEY2|...)= matching only export-style assignments.
  local pattern
  pattern="^[[:space:]]*(export[[:space:]]+)?($(IFS='|'; echo "${OVERRIDE_KEYS[*]}"))="
  grep -Ev "$pattern" "$src" || true
}

# unlink_if_symlink_to <path> <target> — if <path> is a symlink pointing
# (transitively) at <target>, remove it. Guards against `cat target > path`
# bombs when path silently resolves to target.
unlink_if_symlink_to() {
  local path="$1" target="$2"
  [[ -L "$path" ]] || return 0
  local p t
  p="$(/usr/bin/readlink -f "$path" 2>/dev/null || true)"
  t="$(/usr/bin/readlink -f "$target" 2>/dev/null || true)"
  if [[ -n "$p" && "$p" == "$t" ]]; then
    echo "supabase-worktree: removing dangerous symlink ${path} -> ${target}" >&2
    rm -f "$path"
  fi
}

write_wt_env() {
  unlink_if_symlink_to "$WT_ENV" "${ROOT}/.env"

  # Write to a temp file then atomic-rename, so even if $WT_ENV is replaced
  # mid-write we never read-and-truncate the same inode.
  local tmp="${WT_ENV}.tmp.$$"
  {
    if [[ -f "${ROOT}/.env" ]]; then
      echo "# === snapshot of ${ROOT}/.env (regenerated by supabase-worktree init) ==="
      emit_snapshot_without_overrides "${ROOT}/.env"
      echo
    fi
    emit_overrides
  } > "$tmp"
  mv -f "$tmp" "$WT_ENV"
  echo "supabase-worktree: wrote ${WT_ENV}"
}

# write_root_env_local — generates $ROOT/.env.local: a snapshot of $ROOT/.env
# with the supabase-worktree-managed keys stripped, followed by the per-instance
# overrides. Regenerated on every `init` / `up` so repo `.env` edits propagate.
# Bun / Next / one-off scripts auto-load this and target the worktree stack
# without per-command flags.
write_root_env_local() {
  unlink_if_symlink_to "$ROOT_ENV_LOCAL" "${ROOT}/.env"

  local tmp="${ROOT_ENV_LOCAL}.tmp.$$"
  {
    cat <<EOF
# Auto-generated by supabase-worktree — points local tooling at this worktree's
# isolated Supabase stack. Safe to delete; regenerated on every \`supabase-worktree
# init\` / \`up\`. Edit \`$(basename "$ROOT")/.env\` for persistent changes.
EOF
    if [[ -f "${ROOT}/.env" ]]; then
      echo "# === snapshot of ${ROOT}/.env ==="
      emit_snapshot_without_overrides "${ROOT}/.env"
      echo
    fi
    emit_overrides
  } > "$tmp"
  mv -f "$tmp" "$ROOT_ENV_LOCAL"
  echo "supabase-worktree: wrote ${ROOT_ENV_LOCAL}"
}

# run_post_init_hook — if $ROOT/.supabase-worktree.hook is present and
# executable, run it after env files + config.toml have been (re)generated.
# Exports the resolved instance state so the hook can copy extra files
# (e.g. .env.local from the main checkout into a new worktree), seed local
# data, or kick off any project-specific bootstrap.
#
# Fired on every `init` / `up` so re-running propagates repo edits, matching
# the env writers above. Hooks should therefore be idempotent.
run_post_init_hook() {
  if [[ ! -f "$HOOK_FILE" ]]; then
    return 0
  fi
  if [[ ! -x "$HOOK_FILE" ]]; then
    echo "supabase-worktree: ${HOOK_FILE} is not executable — skipping (chmod +x to enable)" >&2
    return 0
  fi
  echo "supabase-worktree: running hook ${HOOK_FILE}"
  SUPABASE_WORKTREE_ROOT="$ROOT" \
  SUPABASE_WORKTREE_NAME="$WORKTREE_NAME" \
  SUPABASE_WORKTREE_PROJECT_ID="$PROJECT_ID" \
  SUPABASE_WORKTREE_BASE_PROJECT_ID="$BASE_PROJECT_ID" \
  SUPABASE_WORKTREE_PORT_OFFSET="$OFFSET" \
  SUPABASE_WORKTREE_DIR="$WT_DIR" \
  SUPABASE_WORKTREE_API_PORT="$WT_API" \
  SUPABASE_WORKTREE_DB_PORT="$WT_DB" \
  SUPABASE_WORKTREE_STUDIO_PORT="$WT_STUDIO" \
  SUPABASE_WORKTREE_INBUCKET_PORT="$WT_INBUCKET" \
  SUPABASE_WORKTREE_ANALYTICS_PORT="$WT_ANALYTICS" \
  SUPABASE_WORKTREE_POOLER_PORT="$WT_POOLER" \
  SUPABASE_WORKTREE_SHADOW_PORT="$WT_SHADOW" \
  SUPABASE_WORKTREE_INSPECTOR_PORT="$WT_INSPECTOR" \
  SUPABASE_WORKTREE_NEXT_PORT="$WT_NEXT_PORT" \
  SUPABASE_WORKTREE_SITE_URL="$SITE_URL" \
  SUPABASE_WORKTREE_DB_URL="$DB_URL" \
    "$HOOK_FILE"
}

# --- subcommands -------------------------------------------------------------

cmd_init() {
  mkdir -p "$WT_SB_DIR"

  for d in migrations functions schemas seeds tests templates; do
    src="${ROOT}/supabase/$d"
    dst="${WT_SB_DIR}/$d"
    if [[ -e "$src" && ! -e "$dst" ]]; then
      ln -s "../../supabase/$d" "$dst"
    fi
  done

  write_wt_env
  write_root_env_local

  if [[ -f "$WT_CONFIG" ]]; then
    echo "supabase-worktree: config already present at $WT_CONFIG"
    run_post_init_hook
    return 0
  fi

  sed \
    -e "s|^project_id = \"${BASE_PROJECT_ID}\"|project_id = \"${PROJECT_ID}\"|" \
    -e "s|port = 54321|port = ${WT_API}|" \
    -e "s|port = 54322|port = ${WT_DB}|" \
    -e "s|shadow_port = 54330|shadow_port = ${WT_SHADOW}|" \
    -e "s|port = 54329|port = ${WT_POOLER}|" \
    -e "s|port = 54323|port = ${WT_STUDIO}|" \
    -e "s|port = 54324|port = ${WT_INBUCKET}|" \
    -e "s|port = 54327|port = ${WT_ANALYTICS}|" \
    -e "s|inspector_port = 8083|inspector_port = ${WT_INSPECTOR}|" \
    -e "s|127.0.0.1:54321|127.0.0.1:${WT_API}|g" \
    "$SOURCE_CONFIG" > "$WT_CONFIG"

  echo "supabase-worktree: wrote ${WT_CONFIG}"
  echo "  project_id: ${PROJECT_ID}"
  printf "  ports: api=%d db=%d studio=%d inbucket=%d analytics=%d pooler=%d shadow=%d inspector=%d\n" \
    "$WT_API" "$WT_DB" "$WT_STUDIO" "$WT_INBUCKET" "$WT_ANALYTICS" "$WT_POOLER" "$WT_SHADOW" "$WT_INSPECTOR"

  run_post_init_hook
}

cmd_up() {
  cmd_init
  # Refresh both env files every `up` so repo .env edits propagate even when
  # the config.toml is already in place (cmd_init returns early in that case).
  write_wt_env
  write_root_env_local
  supabase --workdir "$WT_DIR" start "$@"
}

cmd_ports() {
  # Enumerate every reservable port slot derived from $OFFSETS — the full set
  # of redirect URIs to whitelist in OAuth providers once, so new worktrees
  # never need a console roundtrip.
  local mode="urls"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --urls|--oauth) mode="urls"; shift ;;
      --table)        mode="table"; shift ;;
      --all)          mode="all"; shift ;;
      -h|--help)
        cat <<'EOF'
Usage: supabase-worktree ports [--urls | --table | --all]

  --urls   (default) Print one Supabase auth redirect URI per slot, ready
           to paste into Google / GitHub / etc. OAuth allowed-URIs lists.
  --table  Print a per-slot table (offset, api, db, studio, inbucket, next).
  --all    Print both the table and the URIs.
EOF
        return 0
        ;;
      *) echo "supabase-worktree ports: unknown flag: $1" >&2; return 64 ;;
    esac
  done

  if [[ "$mode" == "table" || "$mode" == "all" ]]; then
    printf "%-7s %-6s %-6s %-6s %-8s %-9s %-7s %-7s %-9s %-5s\n" \
      OFFSET API DB STUDIO INBUCKET ANALYTICS POOLER SHADOW INSPECTOR NEXT
    local off api db studio inbucket analytics pooler shadow inspector next
    for off in "${OFFSETS[@]}"; do
      api=$((54321 + off))
      db=$((54322 + off))
      studio=$((54323 + off))
      inbucket=$((54324 + off))
      analytics=$((54327 + off))
      pooler=$((54329 + off))
      shadow=$((54330 + off))
      inspector=$((8083 + off))
      next=$((3000 + off / 100))
      printf "%-7d %-6d %-6d %-6d %-8d %-9d %-7d %-7d %-9d %-5d\n" \
        "$off" "$api" "$db" "$studio" "$inbucket" "$analytics" "$pooler" "$shadow" "$inspector" "$next"
    done
  fi

  if [[ "$mode" == "all" ]]; then
    echo
  fi

  if [[ "$mode" == "urls" || "$mode" == "all" ]]; then
    local off api
    for off in "${OFFSETS[@]}"; do
      api=$((54321 + off))
      echo "http://127.0.0.1:${api}/auth/v1/callback"
    done
  fi
}

cmd_hook() {
  if [[ ! -f "$HOOK_FILE" ]]; then
    echo "supabase-worktree: no hook at ${HOOK_FILE}" >&2
    return 1
  fi
  if [[ ! -x "$HOOK_FILE" ]]; then
    echo "supabase-worktree: ${HOOK_FILE} exists but is not executable" >&2
    echo "                   chmod +x ${HOOK_FILE}" >&2
    return 1
  fi
  run_post_init_hook
}

cmd_down() {
  supabase --workdir "$WT_DIR" stop "$@"
}

cmd_status() {
  echo "root       : ${ROOT}"
  echo "name       : ${WORKTREE_NAME}"
  echo "project_id : ${PROJECT_ID}"
  echo "config     : ${WT_CONFIG}"
  echo "env file   : ${WT_ENV}"
  if [[ -f "$HOOK_FILE" ]]; then
    if [[ -x "$HOOK_FILE" ]]; then
      echo "hook       : ${HOOK_FILE}"
    else
      echo "hook       : ${HOOK_FILE} (not executable — chmod +x to enable)"
    fi
  fi
  printf "ports      : api=%d db=%d studio=%d inbucket=%d analytics=%d pooler=%d shadow=%d inspector=%d\n" \
    "$WT_API" "$WT_DB" "$WT_STUDIO" "$WT_INBUCKET" "$WT_ANALYTICS" "$WT_POOLER" "$WT_SHADOW" "$WT_INSPECTOR"
  echo "next port  : ${WT_NEXT_PORT}"
  echo "site url   : ${SITE_URL}"
  echo "db url     : ${DB_URL}"
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "supabase_db_${PROJECT_ID}"; then
    echo "status     : RUNNING"
  else
    echo "status     : stopped"
  fi
}

cmd_restore() {
  local dump=""
  local assume_yes=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes|-y) assume_yes=1; shift ;;
      -h|--help)
        cat <<'EOF'
Usage: supabase-worktree restore <dump-file> [--yes]

Restore a custom-format pg_dump into the isolated worktree DB. This is a
DESTRUCTIVE operation — the worktree DB is reset before the restore.

The restore runs in two passes so the local GoTrue / Storage binaries don't
end up pointed at a prod-version schema they cannot read:
  pass 1 — DDL + data for app schemas, EXCLUDING auth, storage, realtime,
           _analytics, _supabase, supabase_functions.
  pass 2 — data-only into auth + storage (keeping the local-version DDL).

After the restore, ownership of public.* / cron.* / supabase_migrations.*
objects is reassigned back to the postgres role so `supabase migration up`
can ALTER them later.

Flags:
  --yes, -y      Skip the confirmation prompt.
EOF
        return 0
        ;;
      --*) echo "supabase-worktree restore: unknown flag: $1" >&2; return 64 ;;
      *)
        if [[ -z "$dump" ]]; then dump="$1"; else
          echo "supabase-worktree restore: unexpected positional arg: $1" >&2; return 64
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$dump" ]]; then
    echo "Usage: supabase-worktree restore <dump-file> [--yes]" >&2
    return 2
  fi
  if [[ ! -f "$dump" ]]; then
    echo "supabase-worktree restore: dump not found: $dump" >&2
    return 1
  fi
  if ! pg_restore -l "$dump" >/dev/null 2>&1; then
    echo "supabase-worktree restore: $dump is not a valid custom-format pg_dump." >&2
    echo "                           (expected output of: pg_dump -Fc ...)" >&2
    return 65
  fi

  # supabase_admin is required to write into auth / storage / realtime during
  # the data-only second pass. The default DB_URL uses the postgres role.
  local admin_url="postgresql://supabase_admin:postgres@127.0.0.1:${WT_DB}/postgres"

  if ! psql "$admin_url" -c 'SELECT 1' >/dev/null 2>&1; then
    echo "supabase-worktree restore: cannot reach the worktree DB at port ${WT_DB}." >&2
    echo "                           Start it first: supabase-worktree up" >&2
    return 69
  fi

  local pg_major
  pg_major=$(pg_restore --version | awk '{print $3}' | cut -d. -f1)
  if [[ "${pg_major}" -lt 15 ]]; then
    echo "supabase-worktree restore: warning — pg_restore v${pg_major} is older than the dump (v15+ recommended)." >&2
  fi

  echo ""
  echo "About to restore:"
  echo "  dump   : ${dump} ($(du -h "${dump}" | cut -f1))"
  echo "  target : ${admin_url}"
  echo "  worktree : ${PROJECT_ID} (db port ${WT_DB})"
  echo ""
  echo "This will WIPE the worktree database (supabase db reset) and replace"
  echo "it with the contents of the dump."

  if [[ $assume_yes -eq 0 ]]; then
    echo ""
    read -r -p "Type 'yes' to continue: " confirm
    if [[ "${confirm}" != "yes" ]]; then
      echo "Aborted."
      return 1
    fi
  fi

  echo ""
  echo "==> Resetting worktree database to clean baseline..."
  supabase --workdir "$WT_DIR" db reset --local

  local log_file
  log_file=$(mktemp -t supabase-worktree-restore.XXXXXX.log)
  local managed_schemas=(auth storage realtime _analytics _supabase supabase_functions)
  local exclude_flags=()
  local s
  for s in "${managed_schemas[@]}"; do exclude_flags+=(--exclude-schema="$s"); done

  echo ""
  echo "==> Pass 1: app schemas (DDL + data, excluding supabase-managed schemas)"
  set +e
  pg_restore \
    --dbname="$admin_url" \
    --no-owner --no-privileges \
    --clean --if-exists \
    --disable-triggers \
    --verbose \
    "${exclude_flags[@]}" \
    "$dump" 2> >(tee "$log_file" >&2)
  local exit1=$?

  echo ""
  echo "==> Pass 2: auth + storage (data-only into local-version DDL)"
  pg_restore \
    --dbname="$admin_url" \
    --no-owner --no-privileges \
    --data-only \
    --disable-triggers \
    --verbose \
    --schema=auth --schema=storage \
    "$dump" 2>> >(tee -a "$log_file" >&2)
  local exit2=$?
  set -e

  echo ""
  echo "==> Reassigning public.* ownership back to postgres (so 'supabase migration up' works)..."
  # The restore ran as supabase_admin (needed for auth/storage writes); flip
  # public-side objects back to the postgres role that migrations expect.
  psql "$admin_url" -v ON_ERROR_STOP=1 >/dev/null <<'SQL'
DO $$
DECLARE r record;
BEGIN
  FOR r IN
    SELECT format('ALTER TABLE %I.%I OWNER TO postgres', schemaname, tablename) AS cmd
      FROM pg_tables WHERE schemaname IN ('public','cron','supabase_migrations')
    UNION ALL
    SELECT format('ALTER SEQUENCE %I.%I OWNER TO postgres', sequence_schema, sequence_name)
      FROM information_schema.sequences WHERE sequence_schema IN ('public','cron','supabase_migrations')
    UNION ALL
    SELECT format('ALTER VIEW %I.%I OWNER TO postgres', schemaname, viewname)
      FROM pg_views WHERE schemaname IN ('public','cron','supabase_migrations')
    UNION ALL
    SELECT format('ALTER FUNCTION %I.%I(%s) OWNER TO postgres',
                  n.nspname, p.proname, pg_get_function_identity_arguments(p.oid))
      FROM pg_proc p JOIN pg_namespace n ON n.oid = p.pronamespace
      WHERE n.nspname IN ('public','cron','supabase_migrations') AND p.prokind = 'f'
    UNION ALL
    SELECT format('ALTER PROCEDURE %I.%I(%s) OWNER TO postgres',
                  n.nspname, p.proname, pg_get_function_identity_arguments(p.oid))
      FROM pg_proc p JOIN pg_namespace n ON n.oid = p.pronamespace
      WHERE n.nspname IN ('public','cron','supabase_migrations') AND p.prokind = 'p'
    UNION ALL
    SELECT format('ALTER TYPE %I.%I OWNER TO postgres', n.nspname, t.typname)
      FROM pg_type t JOIN pg_namespace n ON n.oid = t.typnamespace
      WHERE n.nspname = 'public' AND t.typtype IN ('e','c','d')
        AND NOT EXISTS (SELECT 1 FROM pg_class c WHERE c.reltype = t.oid)
  LOOP
    BEGIN
      EXECUTE r.cmd;
    EXCEPTION WHEN OTHERS THEN
      RAISE NOTICE 'skip: % (%)', r.cmd, SQLERRM;
    END;
  END LOOP;
END $$;
SQL

  local err_count
  err_count=$(grep -c '^pg_restore: error:' "$log_file" || true)

  echo ""
  echo "==> Done."
  echo "    pass 1 exit : ${exit1}"
  echo "    pass 2 exit : ${exit2}"
  echo "    errors      : ${err_count}"
  echo "    log         : ${log_file}"
  if [[ "${err_count}" -gt 0 ]]; then
    echo ""
    echo "Some errors were logged. Most are benign (role grants, extension ownership)."
    echo "Skim the log; if app queries work, you're good."
  fi
}

cmd_psql() {
  exec psql "$DB_URL" "$@"
}

cmd_version() {
  echo "supabase-worktree ${VERSION}"
}

cmd_help() {
  cat <<EOF
supabase-worktree ${VERSION}

Usage: $(basename "$0") <command> [args...]

Commands:
  init                  Generate .supabase-worktree/supabase/config.toml + symlinks
  up [supabase args]    supabase start in the isolated stack
  down [supabase args]  supabase stop in the isolated stack
  status                Show root, project_id, ports, db url, running state
  restore <dump> [-y]   Restore a custom-format pg_dump into the isolated DB
                        (two-pass: app schemas first, then auth/storage data-only)
  psql [args...]        psql into the isolated DB
  ports [--table|--urls|--all]
                        List every reservable port slot. Default mode prints
                        the Supabase auth redirect URIs to paste into your
                        OAuth provider whitelist (Google, GitHub, ...) once
                        so new worktrees don't trigger a console roundtrip.
  hook                  Run \$ROOT/.supabase-worktree.hook on demand (fired
                        automatically after init/up; useful for re-running)
  version               Print the installed version
  help                  Show this message

Env overrides:
  SUPABASE_WORKTREE_NAME         override the derived instance name
  SUPABASE_WORKTREE_PROJECT_ID   override the auto-detected base project_id
  SUPABASE_WORKTREE_PORT_OFFSET  pin a specific port offset
  SUPABASE_WORKTREE_OFFSETS      comma-separated list of reservable offsets
                                 (default: 50 slots, multiples of 100, 0..4900)

Resolved for this invocation:
  root         : ${ROOT}
  name         : ${WORKTREE_NAME}
  base project : ${BASE_PROJECT_ID}
  project_id   : ${PROJECT_ID}
  next port    : ${WT_NEXT_PORT}
  site url     : ${SITE_URL}
  db url       : ${DB_URL}
EOF
}

# --- dispatch ----------------------------------------------------------------

cmd="${1:-help}"
shift || true
case "$cmd" in
  init)            cmd_init    "$@" ;;
  up)              cmd_up      "$@" ;;
  down)            cmd_down    "$@" ;;
  status)          cmd_status  "$@" ;;
  restore)         cmd_restore "$@" ;;
  psql)            cmd_psql    "$@" ;;
  ports)           cmd_ports   "$@" ;;
  hook)            cmd_hook    "$@" ;;
  version|--version|-v) cmd_version ;;
  help|-h|--help)  cmd_help ;;
  *) echo "supabase-worktree: unknown command '$cmd'" >&2; cmd_help; exit 2 ;;
esac
